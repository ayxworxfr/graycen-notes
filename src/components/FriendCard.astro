---
import type { Friend } from "../data/friends";

interface Props {
	friend: Friend;
}

const { friend } = Astro.props;
const initial = friend.name.trim().charAt(0).toUpperCase();
---
<a
    href={friend.url}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`访问 ${friend.name}`}
    class="card-base group flex h-full gap-4 rounded-[var(--radius-large)] p-4 transition active:scale-[0.98]"
>
    <div class="relative h-16 w-16 shrink-0 overflow-hidden rounded-2xl bg-[var(--btn-regular-bg)] dark:bg-white/10">
        <div class="absolute inset-0 flex items-center justify-center text-xl font-bold text-[var(--primary)]">
            {initial}
        </div>
        <img
            src={friend.avatar}
            alt={`${friend.name} avatar`}
            loading="lazy"
            referrerpolicy="no-referrer"
            class="absolute inset-0 h-full w-full object-cover transition group-hover:scale-105"
            onerror="this.remove()"
        />
    </div>
    <div class="min-w-0 flex-1">
        <div class="mb-1 flex items-center gap-2">
            <div class="truncate font-bold text-90 transition group-hover:text-[var(--primary)]">
                {friend.name}
            </div>
            <div class="h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--primary)] opacity-60"></div>
        </div>
        <div class="line-clamp-2 text-sm text-75">
            {friend.description}
        </div>
    </div>
</a>
