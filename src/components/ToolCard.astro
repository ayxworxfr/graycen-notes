---
import { Icon } from "astro-icon/components";
import type { ToolLink } from "../data/tools";
import { url } from "../utils/url-utils";

interface Props {
	tool: ToolLink;
}

const { tool } = Astro.props;
const href = tool.external ? tool.url : url(tool.url);
---
<a
    href={href}
    target={tool.external ? "_blank" : undefined}
    rel={tool.external ? "noopener noreferrer" : undefined}
    aria-label={`打开${tool.title}`}
    class="card-base group flex h-full items-center gap-4 rounded-[var(--radius-large)] p-5 transition active:scale-[0.98]"
>
    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-[var(--btn-regular-bg)] text-[var(--primary)] transition group-hover:bg-[var(--primary)] group-hover:text-[var(--deep-text)]">
        <Icon name={tool.icon} class="text-[1.65rem]" />
    </div>
    <div class="min-w-0 flex-1">
        <div class="mb-1 truncate font-bold text-90 transition group-hover:text-[var(--primary)]">
            {tool.title}
        </div>
        <div class="line-clamp-2 text-sm text-75">
            {tool.description}
        </div>
    </div>
</a>
