---
import ToolCard from "@components/ToolCard.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";
import { tools } from "../data/tools";
---
<MainGridLayout title="工具" description="Graycen Notes 的实用工具和资源入口">
    <section class="card-base mb-4 rounded-[var(--radius-large)] px-6 py-6 md:px-9">
        <div class="mb-2 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--primary)] text-white">
                <Icon name="material-symbols:build-outline-rounded" class="text-[1.5rem]"></Icon>
            </div>
            <h1 class="text-2xl font-bold text-90">工具</h1>
        </div>
        <p class="text-75">
            本站提供的实用工具入口，点击卡片即可跳转使用。
        </p>
    </section>

    {tools.length > 0 ? (
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {tools.map((tool) => <ToolCard tool={tool} />)}
        </div>
    ) : (
        <section class="card-base rounded-[var(--radius-large)] px-6 py-10 text-center text-75">
            还没有添加工具。
        </section>
    )}
</MainGridLayout>
